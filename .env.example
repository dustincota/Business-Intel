# Hedgestone M&A Intelligence Platform — Environment Variables
# Copy to .env and fill in your keys:  cp .env.example .env

# Supabase (required — all scripts)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Google Places API (for GP scanners only — $0 budget currently)
GOOGLE_API_KEY=your-google-api-key

# Apollo.io (for people/org enrichment)
APOLLO_API_KEY=your-apollo-api-key

# Apify (for LinkedIn, Yelp, Google Maps scraping)
APIFY_API_TOKEN=your-apify-token
